[app]
# (str) Title of your application
title = My Application

# (str) Package name
package.name = my.application

# (str) Package domain
package.domain = org.example

# (str) Source code where the main.py is located
source.dir = .

# (list) The application requirements
requirements = python3,kivy==2.3.0,requests==2.31.0,plyer==2.4.0

# (str) Version of your application
version = 0.1

# (str) The source code file for the main application
main = main.py

# (list) Permissions
android.permissions = INTERNET

# (list) Application icons
android.icon = "icon.png"
